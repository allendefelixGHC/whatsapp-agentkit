# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=whapi

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────
# Obtener en: https://whapi.cloud (plan gratis disponible)
WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Webhook Authentication ────────────────────────────
# Secreto para el header de autenticación del webhook de Whapi.
# Generar con: openssl rand -hex 32
# Luego ejecutar tools/configure_whapi_webhook.py para registrarlo en Whapi.
# Si está vacío, la autenticación Whapi está desactivada (modo degradado).
WHAPI_WEBHOOK_SECRET=
# Si true, rechaza webhooks de GHL que no tengan X-GHL-Signature (modo estricto).
# Default false: permite webhooks GHL sin firma (ej: automatizaciones internas de GHL).
GHL_WEBHOOK_AUTH_STRICT=false

# ── Rate Limiting ──────────────────────────────────────
# Máximo de mensajes por número de teléfono por minuto antes de activar el rate limit.
# Default 15 (2-5x el uso normal de una conversación activa por WhatsApp).
RATE_LIMIT_PER_MINUTE=15

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
